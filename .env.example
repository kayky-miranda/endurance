# Banco Postgres. Cole a connection string do seu provedor (Neon/Supabase/etc.).
# Use a URL com pooling para serverless (ex.: ...-pooler... / pgbouncer=true).
# Depois rode `npm run db:push` para criar as tabelas.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Segredo para assinar os cookies de sessão (JWT). Gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=""

# Provedor de IA do onboarding. Configure UMA das chaves abaixo (Gemini tem
# prioridade). Sem nenhuma, o onboarding roda em modo demonstração
# (classificador por palavras-chave).

# Google Gemini — tier GRATUITO (sem cartão): https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# (opcional) trocar o modelo do Gemini; padrão: gemini-2.0-flash
# GEMINI_MODEL="gemini-2.0-flash"

# Claude (Anthropic) — alternativa paga: https://console.anthropic.com
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# EMISSÃO FISCAL REAL — Focus NFe (NFC-e modelo 65)
# -----------------------------------------------------------------------------
# Por padrão a emissão é SIMULADA (protótipo). Para emitir de verdade, na tela
# Fiscal de cada empresa escolha "Real · Focus NFe" e preencha o NCM padrão; o
# certificado A1 e o CNPJ ficam cadastrados no painel do Focus NFe.
#
# Token de HOMOLOGAÇÃO (sandbox — notas SEM valor fiscal). Comece sempre por aqui:
#   https://app.focusnfe.com.br  → Configurações → Tokens
FOCUS_NFE_TOKEN_HOMOLOGACAO=""
# Token de PRODUÇÃO (notas COM valor fiscal). Deixe vazio até validar tudo.
FOCUS_NFE_TOKEN_PRODUCAO=""
# Trava de segurança: a emissão em PRODUÇÃO só é liberada com isto = "true"
# (além de ambiente=1 na empresa e do token de produção acima). Mantenha
# desligado enquanto estiver testando.
# FOCUS_NFE_ALLOW_PRODUCTION="true"

# -----------------------------------------------------------------------------
# COBRANÇA PIX — Mercado Pago
# -----------------------------------------------------------------------------
# Por padrão a cobrança é SIMULADA (BR Code gerado da chave PIX da empresa, na
# tela Notificações → Integrações). Para cobrar de verdade, escolha "Mercado
# Pago" na config da empresa e preencha o token abaixo.
# Token de TESTE tem prefixo "TEST-" (sandbox); qualquer outro é produção.
MERCADO_PAGO_ACCESS_TOKEN=""
# Trava de segurança: cobrança PIX em PRODUÇÃO só é liberada com isto = "true"
# (token de teste TEST-… funciona sem a flag). Mantenha desligado ao testar.
# PIX_ALLOW_PRODUCTION="true"
# (opcional) URL pública do app, para o webhook do PSP em /api/pix/webhook.
# APP_URL="https://seu-dominio.com"

# -----------------------------------------------------------------------------
# WHATSAPP BUSINESS — Meta Cloud API
# -----------------------------------------------------------------------------
# Por padrão o envio é SIMULADO (só registra a mensagem). Para enviar de verdade,
# escolha "Meta Cloud API" na config, preencha o Phone Number ID na empresa e o
# token abaixo, e ligue a flag.
WHATSAPP_TOKEN=""
# Token de verificação do webhook (/api/whatsapp/webhook) — defina o mesmo valor
# no painel da Meta ao assinar o webhook.
WHATSAPP_VERIFY_TOKEN=""
# Trava de segurança: o envio real só acontece com isto = "true".
# WHATSAPP_ALLOW_SEND="true"
