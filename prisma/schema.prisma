// ENDURANCE — banco do protótipo.
// Multi-tenant por schema único: cada negócio é uma Organization e os módulos
// ativados ficam em OrgModule (o "registry de módulos" persistido).
// Postgres (produção/Vercel). Em dev local, aponte DATABASE_URL para o mesmo
// Postgres hospedado (não há mais SQLite).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  niche      String
  nicheLabel String
  city       String   @default("")
  state      String   @default("")
  country    String   @default("")
  segment    String   @default("")
  createdAt  DateTime @default(now())

  modules          OrgModule[]
  users            User[]
  products         Product[]
  sales            Sale[]
  customers        Customer[]
  fiscalConfig     FiscalConfig?
  fiscalDocs       FiscalDocument[]
  cashSessions     CashSession[]
  finEntries       FinancialEntry[]
  suppliers        Supplier[]
  purchases        PurchaseOrder[]
  categories       Category[]
  importedInvoices ImportedInvoice[]
  activityLogs     ActivityLog[]
  aiUsage          AiUsage[]
  subscription     Subscription?
  invoices         Invoice[]
  pixCharges       PixCharge[]
  pixConfig        PixConfig?
  whatsappConfig   WhatsAppConfig?
  whatsappMessages WhatsAppMessage[]
}

// Assinatura SaaS do espaço (uma por organização). No protótipo a cobrança é
// auto-gerida (sem provedor de pagamento externo): a troca de plano é imediata
// e gera uma fatura interna. O modelo segue o vocabulário de provedores reais
// (status trialing/active/past_due/canceled, cancelamento ao fim do ciclo) para
// que um Stripe/Iugu possa ser plugado depois sem reescrever as telas.
model Subscription {
  id                 String    @id @default(cuid())
  organizationId     String    @unique
  plan               String    @default("starter") // starter | professional | business | enterprise
  status             String    @default("trialing") // trialing | active | past_due | canceled
  seats              Int       @default(2) // limite de usuários do plano
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  trialEndsAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
}

// Fatura interna gerada a cada cobrança/troca de plano paga. Guarda o valor
// congelado do plano e o período coberto — base do histórico de cobrança.
model Invoice {
  id             String    @id @default(cuid())
  organizationId String
  subscriptionId String
  number         String // número humano sequencial (ex.: 2026-0001)
  plan           String
  amount         Decimal   @db.Decimal(12, 2)
  status         String    @default("paga") // paga | pendente | falhou
  periodStart    DateTime
  periodEnd      DateTime
  issuedAt       DateTime  @default(now())
  paidAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([organizationId, issuedAt])
}

// Telemetria de IA por organização: cada chamada a um provedor (ou queda na
// heurística offline) vira um registro com tokens, latência e resultado.
// organizationId é nulo nas chamadas pré-tenant (onboarding, antes do signup).
model AiUsage {
  id             String   @id @default(cuid())
  organizationId String?
  feature        String // assistant | onboarding | sales_insights | stock_advice | crm_campaigns | pricing_advice
  provider       String // gemini | anthropic | offline
  model          String   @default("")
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  latencyMs      Int      @default(0)
  ok             Boolean  @default(true)
  fallback       Boolean  @default(false) // resolveu pela heurística offline
  error          String   @default("")
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// Nota fiscal importada por XML (NF-e modelo 55 / NFC-e modelo 65). Registro
// para migração/auditoria — guarda o cabeçalho parseado + o XML bruto.
// Idempotente por chave de acesso dentro da organização.
model ImportedInvoice {
  id             String   @id @default(cuid())
  organizationId String
  chave          String
  modelo         String   @default("55")
  serie          Int      @default(0)
  numero         Int      @default(0)
  emitCnpj       String   @default("")
  emitNome       String   @default("")
  total          Decimal  @default(0) @db.Decimal(12, 2)
  itemsCount     Int      @default(0)
  dhEmi          DateTime @default(now())
  xml            String
  // Lançamentos gerados a partir da nota (entrada de estoque / conta a pagar).
  // Ficam no header porque a importação é idempotente por chave: só a primeira
  // importação de uma chave lança estoque/financeiro.
  appliedStock   Boolean  @default(false)
  appliedPayable Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, chave])
  @@index([organizationId])
}

// Registro de categorias (alimentado pela importação em massa; reutilizável em
// filtros/cadastros). Único por nome dentro da organização.
model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

// Fornecedor do negócio (compras / reposição de estoque).
model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  cnpj           String   @default("")
  phone          String   @default("")
  email          String   @default("")
  note           String   @default("")
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       PurchaseOrder[]

  @@index([organizationId])
}

// Pedido de compra. Ao ser RECEBIDO: dá entrada no estoque dos itens e gera uma
// conta a pagar no financeiro (fechando o ciclo reposição → compra → estoque → $).
model PurchaseOrder {
  id             String    @id @default(cuid())
  organizationId String
  supplierId     String
  status         String    @default("enviado") // enviado | recebido | cancelado
  total          Decimal   @default(0) @db.Decimal(12, 2)
  note           String    @default("")
  createdAt      DateTime  @default(now())
  receivedAt     DateTime?
  sentAt         DateTime? // quando o pedido foi enviado ao fornecedor
  sentVia        String    @default("") // whatsapp | email | manual

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items        PurchaseOrderItem[]

  @@index([organizationId])
}

model PurchaseOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  name      String
  quantity  Int
  unitCost  Decimal @db.Decimal(12, 2)

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Sessão de caixa (turno do PDV). Abre com um fundo de troco e fecha com a
// conferência do dinheiro contado x esperado. Vendas feitas com o caixa aberto
// ficam vinculadas a ele para compor o esperado em dinheiro.
model CashSession {
  id             String    @id @default(cuid())
  organizationId String
  userId         String?
  status         String    @default("aberto") // aberto | fechado
  openingAmount  Decimal   @default(0) @db.Decimal(12, 2)
  countedAmount  Decimal?  @db.Decimal(12, 2) // informado no fechamento
  expectedAmount Decimal?  @db.Decimal(12, 2) // congelado no fechamento
  difference     Decimal?  @db.Decimal(12, 2) // contado - esperado
  note           String    @default("")
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements    CashMovement[]
  sales        Sale[]

  @@index([organizationId])
}

// Movimento de caixa: suprimento (reforço) ou sangria (retirada).
model CashMovement {
  id        String   @id @default(cuid())
  sessionId String
  type      String // suprimento | sangria
  amount    Decimal  @db.Decimal(12, 2)
  reason    String   @default("")
  userId    String?
  createdAt DateTime @default(now())

  session CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// Lançamento financeiro: conta a receber ou a pagar. Os recebíveis são gerados
// automaticamente a partir das formas de pagamento das vendas do PDV.
model FinancialEntry {
  id             String    @id @default(cuid())
  organizationId String
  kind           String // receber | pagar
  description    String
  category       String    @default("")
  amount         Decimal   @db.Decimal(12, 2)
  status         String    @default("pendente") // pendente | pago
  method         String    @default("")
  saleId         String?
  dueDate        DateTime
  paidAt         DateTime?
  // Conciliação: quando o recebível foi batido contra a cobrança/extrato externo.
  reconciledAt   DateTime?
  externalRef    String    @default("") // referência externa (txid PIX, id de extrato)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, kind])
}

// Configuração fiscal da empresa (emitente da NFC-e, modelo 65). Uma por org.
// crt: regime tributário (1=Simples Nacional, 3=Regime Normal).
// ambiente: 1=Produção, 2=Homologação. csc/cscId: credencial do QR Code.
model FiscalConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  cnpj           String   @default("")
  razaoSocial    String   @default("")
  nomeFantasia   String   @default("")
  ie             String   @default("")
  crt            String   @default("1")
  uf             String   @default("SP")
  cMun           String   @default("")
  municipio      String   @default("")
  serie          Int      @default(1)
  proxNumero     Int      @default(1)
  ambiente       String   @default("2")
  cscId          String   @default("000001")
  csc            String   @default("")
  // Emissão real: "" = simulada (protótipo) | "focusnfe" = provedor homologado.
  provider       String   @default("")
  // NCM padrão dos itens (8 díg.) quando o produto não tem NCM próprio. A SEFAZ
  // valida o NCM, então a emissão real exige ao menos este default por empresa.
  defaultNcm     String   @default("")
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Documento fiscal emitido (NFC-e, modelo 65) vinculado a uma venda do PDV.
// No protótipo a autorização SEFAZ é simulada (protocolo/data), mas a chave de
// acesso, o dígito verificador, o QR Code e o XML seguem o layout oficial 4.00.
model FiscalDocument {
  id              String    @id @default(cuid())
  organizationId  String
  saleId          String    @unique
  modelo          String    @default("65")
  serie           Int
  numero          Int
  chave           String    @unique
  status          String    @default("autorizada") // autorizada | cancelada
  ambiente        String
  protocolo       String    @default("")
  qrCode          String    @default("")
  xml             String    @default("")
  valorTotal      Decimal   @db.Decimal(12, 2)
  motivoCancel    String    @default("")
  // Rastreabilidade do provedor de emissão real (vazio quando simulado).
  provider        String    @default("") // "" | "focusnfe"
  providerRef     String    @default("") // referência idempotente enviada ao provedor
  danfeUrl        String    @default("") // URL do DANFE/cupom no provedor
  dataEmissao     DateTime  @default(now())
  dataAutorizacao DateTime?
  dataCancel      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Cliente do negócio (CRM). Pode ser cadastrado na hora da venda no PDV.
model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String   @default("")
  email          String   @default("")
  document       String   @default("")
  createdAt      DateTime @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales            Sale[]
  whatsAppMessages WhatsAppMessage[]

  @@index([organizationId])
}

// Produto do catálogo de um negócio (módulo Cadastro de produtos / Estoque).
// Sempre escopado por organizationId — isolamento multi-tenant.
model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sku            String   @default("")
  barcode        String   @default("")
  category       String   @default("")
  price          Decimal  @default(0) @db.Decimal(12, 2)
  cost           Decimal  @default(0) @db.Decimal(12, 2)
  stock          Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, barcode])
}

// Venda registrada no PDV. Baixa o estoque dos produtos no fechamento.
model Sale {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String?
  userId         String?
  cashSessionId  String?
  token          String   @unique
  subtotal       Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  change         Decimal  @default(0) @db.Decimal(12, 2) // troco devolvido em dinheiro
  itemsCount     Int
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  seller       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  cashSession  CashSession?    @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  items        SaleItem[]
  payments     SalePayment[]
  fiscalDoc    FiscalDocument?
  pixCharge    PixCharge?

  @@index([organizationId])
  @@index([customerId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String?
  name      String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

// Pagamento de uma venda (permite split: várias formas na mesma venda).
model SalePayment {
  id     String  @id @default(cuid())
  saleId String
  method String // dinheiro | credito | debito | pix
  amount Decimal @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// Usuário de uma organização. role: OWNER | ADMIN | MEMBER (string — SQLite não
// suporta enum no Prisma). email é único global (login por e-mail + senha).
// O RBAC granular fica em `permissions` (ids do catálogo lib/endurance/permissions.ts);
// `profile` guarda o perfil pré-configurado escolhido (ou "" se personalizado).
// `status` controla bloqueio (active | blocked). `lastLoginAt` registra o último acesso.
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           String    @default("MEMBER")
  phone          String    @default("")
  jobTitle       String    @default("") // cargo
  profile        String    @default("") // id do perfil pré-configurado
  permissions    String[]  @default([]) // ids de permissão (RBAC granular)
  status         String    @default("active") // active | blocked
  lastLoginAt    DateTime?
  organizationId String
  createdAt      DateTime  @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales            Sale[]
  whatsappMessages WhatsAppMessage[]

  @@index([organizationId])
}

// Trilha de auditoria: registra ações relevantes (criação/edição/bloqueio de
// usuários, etc.) por organização, para o "Histórico de atividades".
model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String? // quem executou a ação
  actorName      String   @default("")
  action         String // ex.: user.create | user.update | user.block | user.unblock | user.delete
  detail         String   @default("") // descrição legível da ação
  targetId       String? // id do alvo (ex.: usuário afetado)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model OrgModule {
  id             String  @id @default(cuid())
  organizationId String
  moduleId       String
  enabled        Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, moduleId])
  @@index([organizationId])
}

// Cobrança PIX gerada no PDV. No fluxo assíncrono, a venda (Sale) só é criada
// quando a cobrança é confirmada como `pago`. Idempotente por `token` (o mesmo
// token de venda do PDV) e por `txid`. provider="" = simulado (BR Code gerado
// localmente); "mercadopago" = cobrança real via PSP. e2eId é o end-to-end id
// do PIX (preenchido na confirmação). reconciledAt marca a conciliação.
model PixCharge {
  id             String    @id @default(cuid())
  organizationId String
  saleId         String?   @unique // ligado quando a venda é finalizada
  token          String    @unique // = token da venda no PDV (idempotência)
  txid           String    @unique
  amount         Decimal   @db.Decimal(12, 2)
  status         String    @default("pendente") // pendente | pago | expirado | cancelado
  brCode         String    @default("") // copia-e-cola (payload EMV); vazio quando vai pra maquininha
  qrImage        String    @default("") // QR como data URL / URL (opcional)
  provider       String    @default("") // "" simulado | "mercadopago"
  providerRef    String    @default("") // id da cobrança no PSP (ou da payment-intent, na maquininha)
  // Maquininha (Mercado Pago Point): cobrança exibida na tela do terminal.
  terminal       Boolean   @default(false)
  deviceId       String    @default("") // id do aparelho quando terminal=true
  e2eId          String    @default("") // end-to-end id do PIX (na confirmação)
  expiresAt      DateTime?
  paidAt         DateTime?
  reconciledAt   DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sale         Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
}

// Configuração PIX da empresa (uma por org). O token do PSP fica em variável de
// ambiente no servidor (espelha o Focus NFe); aqui só os dados não-secretos.
model PixConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  // "" = simulado (BR Code da chave) | "mercadopago" = cobrança real.
  provider       String   @default("")
  pixKey         String   @default("") // chave PIX do recebedor (BR Code simulado)
  beneficiario   String   @default("") // nome do recebedor (máx. 25 no EMV)
  cidade         String   @default("") // cidade do recebedor (máx. 15 no EMV)
  expiraSegundos Int      @default(3600)
  // Maquininha (Mercado Pago Point): id do aparelho pareado para exibir o QR.
  deviceId       String   @default("")
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Configuração WhatsApp Business da empresa (uma por org). O token Meta fica em
// variável de ambiente no servidor; aqui só os identificadores não-secretos.
model WhatsAppConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  provider       String   @default("") // "" simulado | "meta"
  phoneNumberId  String   @default("") // Phone Number ID da Cloud API
  remetente      String   @default("") // número/nome exibido
  enabled        Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Log de mensagens WhatsApp enviadas (cobrança PIX, recibo, recompra CRM, manual).
model WhatsAppMessage {
  id             String    @id @default(cuid())
  organizationId String
  customerId     String?
  toPhone        String
  kind           String    @default("manual") // pix | recibo | crm | manual
  body           String    @default("")
  templateName   String    @default("")
  status         String    @default("enfileirado") // enfileirado | enviado | entregue | lido | falha
  provider       String    @default("") // "" simulado | "meta"
  providerRef    String    @default("") // id da mensagem no provedor (wamid)
  error          String    @default("")
  createdAt      DateTime  @default(now())
  sentAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user         User?        @relation(fields: [userId], references: [id])
  userId       String?

  @@index([organizationId, status])
  @@index([providerRef])
}
